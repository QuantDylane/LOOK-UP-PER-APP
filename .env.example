# ── Django ───────────────────────────────────────────────────────────────────
# Clé secrète Django. En production, remplacer par une valeur aléatoire longue.
DJANGO_SECRET_KEY=django-insecure-changeme

# Mode debug (True en dev, False en prod)
DJANGO_DEBUG=True

# Hôtes autorisés (séparés par des virgules). Exemple : localhost,127.0.0.1,mondomaine.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── Cache ────────────────────────────────────────────────────────────────────
# Backend de cache (laisser vide pour LocMemCache en dev)
# Exemple Redis :
# DJANGO_CACHE_BACKEND=django.core.cache.backends.redis.RedisCache
# DJANGO_CACHE_LOCATION=redis://127.0.0.1:6379/1
DJANGO_CACHE_BACKEND=django.core.cache.backends.locmem.LocMemCache
DJANGO_CACHE_LOCATION=unique-snowflake
